<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Left side of the U logo (Neon Teal gradient) -->
    <path
        android:pathData="M 38,34 L 38,62 C 38,71 45,78 54,78 C 54,78 54,78 54,78 L 54,72 C 48,72 44,68 44,62 L 44,34 Z"
        android:strokeWidth="1">
        <aapt:attr name="android:fillColor">
            <gradient
                android:endX="54"
                android:endY="78"
                android:startX="38"
                android:startY="34"
                android:type="linear">
                <item
                    android:color="#00FFF0"
                    android:offset="0.0" />
                <item
                    android:color="#00B8D4"
                    android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Right side of the U logo (Deep Rose Pink gradient) -->
    <path
        android:pathData="M 70,34 L 70,62 C 70,71 63,78 54,78 C 54,78 54,78 54,78 L 54,72 C 60,72 64,68 64,62 L 64,34 Z"
        android:strokeWidth="1">
        <aapt:attr name="android:fillColor">
            <gradient
                android:endX="54"
                android:endY="78"
                android:startX="70"
                android:startY="34"
                android:type="linear">
                <item
                    android:color="#FF1493"
                    android:offset="0.0" />
                <item
                    android:color="#C2185B"
                    android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Chat bubble indicator (glowing circular dot inside the U) -->
    <path
        android:pathData="M 54,36 A 4,4 0 1,1 50,36 A 4,4 0 1,1 54,36"
        android:fillColor="#00FFF0" />

    <path
        android:pathData="M 62,44 A 3,3 0 1,1 59,44 A 3,3 0 1,1 62,44"
        android:fillColor="#FF1493" />
</vector>
